  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.0",
    "@playwright/test": "^1.42.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wrangler": "^3.35.0"
  }
