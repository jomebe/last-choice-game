{
  "name": "last-choice-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev --compatibility-date=2024-04-03 --durable-object=GAME_ROOMS=GameRoom --persist",
